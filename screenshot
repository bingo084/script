#!/usr/bin/env bash

# screenshot - Wrapper script for hyprshot with satty annotation
# Usage: rcreenshot [output|window|region|active|OUTPUT_NAME]

mode="${1:-region}"

prev_clipboard_hash=$(wl-paste | sha1sum)

hyprshot -z --clipboard-only -s -m "$mode"

while [ "$(wl-paste | sha1sum)" = "$prev_clipboard_hash" ]; do
  sleep 0.01
done

wl-paste | satty --filename -
