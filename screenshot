#!/usr/bin/env bash

# screenshot - Cross-desktop screenshot with satty annotation
# Usage: screenshot [output|window|region|active]

mode="${1:-region}"
annotate=false

case "$mode" in
  region) annotate=true ;;
esac

prev_clipboard_hash=$(wl-paste 2>/dev/null | sha1sum)

if [ "$XDG_SESSION_DESKTOP" = "hyprland" ]; then
  hyprshot -z --clipboard-only -s -m "$mode"
elif [ "$XDG_SESSION_DESKTOP" = "niri" ]; then
  case "$mode" in
    output)  niri msg action screenshot-screen ;;
    window)
      wid=$(niri msg --json pick-window | jq .id)
      [ -n "$wid" ] && [ "$wid" != "null" ] && niri msg action screenshot-window --id "$wid"
      ;;
    active)  niri msg action screenshot-window ;;
    region)  niri msg action screenshot ;;
    *)       niri msg action screenshot ;;
  esac
else
  echo "Unsupported desktop: $XDG_SESSION_DESKTOP" >&2
  exit 1
fi

if [ "$annotate" = true ]; then
  # 等待截图完成（剪贴板内容变化）
  tries=0
  while [ "$(wl-paste 2>/dev/null | sha1sum)" = "$prev_clipboard_hash" ]; do
    sleep 0.05
    tries=$((tries + 1))
    if [ "$tries" -ge 100 ]; then
      exit 0
    fi
  done
  wl-paste | satty --filename -
fi
